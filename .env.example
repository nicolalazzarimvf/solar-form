# Google APIs
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Ideal Postcodes API
# Docs: https://docs.ideal-postcodes.co.uk/docs/guides
VITE_IDEAL_POSTCODES_API_KEY=your_ideal_postcodes_api_key_here

# Google Sheets
VITE_GOOGLE_SHEET_ID=your_google_sheet_id_here

# Project Solar API (submit-booking, log-exit, log-interaction)
VITE_PROJECT_SOLAR_API_URL=https://wakypxxobpdvqwblheio.supabase.co/functions/v1
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# MVF / Project Solar API (book-appointment, get-availability, appointments)
VITE_PROJECT_SOLAR_MVF_API_URL=https://sejpbjqjfxmehyvlweil.supabase.co/functions/v1
VITE_PROJECT_SOLAR_MVF_API_KEY=your_mvf_api_key_here

# Funnel dashboard telemetry (optional — Heroku Postgres via Vercel ingest)
# Full URL to POST /api/telemetry on the funnel-dashboard app
VITE_FUNNEL_TELEMETRY_URL=
# Same secret as TELEMETRY_INGEST_SECRET on the dashboard
VITE_FUNNEL_TELEMETRY_KEY=

# Note: Server-side only credentials (Supabase Edge Functions) (do not expose to client)
# GOOGLE_SHEETS_CREDENTIALS - Service account JSON for Google Sheets
# These should be configured in your Edge Functions or backend
