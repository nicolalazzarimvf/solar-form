# Auth.js / NextAuth (https://authjs.dev)
AUTH_SECRET=generate_with_openssl_rand_base64_32
AUTH_URL=http://localhost:3000

# Google OAuth — restrict sign-in to @mvfglobal.com in src/auth.ts
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Heroku Postgres (same URI as Heroku config var DATABASE_URL)
DATABASE_URL=postgresql://user:pass@host:5432/dbname?sslmode=require

# Ingest API (solar-form iframe POSTs here)
TELEMETRY_INGEST_SECRET=long_random_string

# Comma-separated origins for CORS on POST /api/telemetry (production solar-form URL)
ALLOWED_CORS_ORIGINS=http://localhost:5173,https://solar-form-eight.vercel.app,https://solar-form-git-experimental-mvfs-projects-bffd3209.vercel.app

# Optional (find-slots on dashboard): MVF_FUNCTIONS_BASE, MVF_API_KEY, ALLOWED_OUTWARD_CODES_PATH
